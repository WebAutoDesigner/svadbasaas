generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Super-admin (владелец продукта) — отдельная сущность с собственной auth.
// Не использует Better-Auth — простой email/password.
// =============================================================================

model SuperAdmin {
  id           String              @id @default(cuid())
  email        String              @unique
  passwordHash String
  name         String?
  createdAt    DateTime            @default(now())
  sessions     SuperAdminSession[]
}

model SuperAdminSession {
  id           String     @id @default(cuid())
  superAdminId String
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime   @default(now())

  @@index([expiresAt])
}

// =============================================================================
// Better-Auth core tables (user/session/account/verification)
// Для agency-пользователей. Поля соответствуют Better-Auth дефолтному адаптеру.
// =============================================================================

model User {
  id            String   @id
  email         String   @unique
  name          String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions             Session[]
  accounts             Account[]
  memberships          AgencyMember[]
  coordinatedWeddings  Wedding[]      @relation("WeddingCoordinator")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  // Активное агентство для multi-tenant изоляции (если у user несколько membership)
  activeAgencyId String?

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

// =============================================================================
// Tenant: Agency + members + roles
// =============================================================================

enum Role {
  OWNER
  ADMIN
  COORDINATOR
}

model Agency {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members         AgencyMember[]
  auditLogs       AuditLog[]
  weddings        Wedding[]
  vendorDirectory AgencyVendor[]
  templates       Template[]

  @@index([isActive])
}

model AgencyMember {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @default(OWNER)
  createdAt DateTime @default(now())

  @@unique([agencyId, userId])
  @@index([userId])
}

// =============================================================================
// Audit log — все мутирующие действия (создание/удаление/изменение прав)
// =============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  agencyId   String?
  agency     Agency?  @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  // userId — свободный идентификатор актора (User.id ИЛИ SuperAdmin.id), без FK.
  // Audit-лог иммутабелен: не должен ломаться FK при действиях супер-админа и не
  // должен терять автора при удалении юзера. Тип актора виден по префиксу action.
  userId     String?
  action     String
  targetType String?
  targetId   String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([agencyId, createdAt])
  @@index([action, createdAt])
}

// =============================================================================
// Wedding — основная сущность (проект свадьбы)
// =============================================================================

enum WeddingStatus {
  PLANNING
  COMPLETED
  CANCELLED
}

model Wedding {
  id            String        @id @default(cuid())
  agencyId      String
  agency        Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  brideName     String
  groomName     String
  date          DateTime // дата свадьбы (UTC, дата без точного времени — время дня в Phase 9)
  timezone      String        @default("Europe/Moscow")
  budget        Int           @default(0) // плановый бюджет, рубли
  location      String?
  guestCount    Int?
  coordinatorId String?
  coordinator   User?         @relation("WeddingCoordinator", fields: [coordinatorId], references: [id], onDelete: SetNull)
  status        WeddingStatus @default(PLANNING)
  deletedAt     DateTime? // soft delete
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Когда агентство последний раз просматривало правки пары (подсистема couple-activity)
  guestsSeenByAgencyAt  DateTime?
  seatingSeenByAgencyAt DateTime?

  // Удобство агентства (agency-only)
  source    String? // откуда пришла пара (Instagram, сарафан…)
  agencyFee Int     @default(0) // гонорар агентства за свадьбу, рубли

  checklistItems   ChecklistItem[]
  budgetItems      BudgetItem[]
  vendors          Vendor[]
  documents        Document[]
  timelineEvents   TimelineEvent[]
  coupleAccess     CoupleAccess?
  guests           Guest[]
  seatingTables    SeatingTable[]
  coupleActivities CoupleActivity[]
  events           WeddingEvent[]
  contacts         WeddingContact[]
  notes            WeddingNote[]
  payments         AgencyPayment[]
  requests         CoupleRequest[]

  @@index([agencyId, deletedAt])
  @@index([agencyId, date])
}

// =============================================================================
// Чек-лист подготовки — плоский список задач, сгруппированный по периодам
// =============================================================================

enum ChecklistPeriod {
  SIX_MONTHS
  THREE_MONTHS
  ONE_MONTH
  ONE_WEEK
  ONE_DAY
  AFTER
}

model ChecklistItem {
  id        String          @id @default(cuid())
  weddingId String
  wedding   Wedding         @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  title     String
  period    ChecklistPeriod
  done      Boolean         @default(false)
  note      String?
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([weddingId])
}

// =============================================================================
// Бюджет — статьи расходов план/факт
// =============================================================================

model BudgetItem {
  id        String   @id @default(cuid())
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name      String
  planned   Int      @default(0) // план, рубли
  actual    Int      @default(0) // факт, рубли
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weddingId])
}

// =============================================================================
// Подрядчики свадьбы
// =============================================================================

enum PaymentStatus {
  NOT_PAID
  PARTIAL
  PAID
}

model Vendor {
  id            String        @id @default(cuid())
  weddingId     String
  wedding       Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name          String
  service       String // тип услуги: ведущий, фото и т.д.
  contact       String? // телефон/мессенджер/email одной строкой
  amount        Int           @default(0) // стоимость, рубли
  paymentStatus PaymentStatus @default(NOT_PAID)
  note          String?
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([weddingId])
}

// =============================================================================
// Документы — файлы свадьбы (локальное хранилище на VPS)
// =============================================================================

model Document {
  id           String   @id @default(cuid())
  weddingId    String
  wedding      Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name         String
  storageKey   String // путь внутри UPLOAD_DIR
  mime         String
  size         Int
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([weddingId])
}

// =============================================================================
// Тайминг свадебного дня
// =============================================================================

model TimelineEvent {
  id           String   @id @default(cuid())
  weddingId    String
  wedding      Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  startMinutes Int // минуты от 00:00
  durationMin  Int      @default(0)
  title        String
  description  String?
  responsible  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([weddingId, startMinutes])
}

// =============================================================================
// Доступ пары (молодожёнов) — вход по email + одноразовый код (magic link)
// =============================================================================

model CoupleAccess {
  id            String          @id @default(cuid())
  weddingId     String          @unique
  wedding       Wedding         @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  email         String
  name          String?
  codeHash      String?
  codeExpiresAt DateTime?
  failedTries   Int             @default(0)
  lockedUntil   DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime        @default(now())
  sessions      CoupleSession[]

  @@index([email])
}

model CoupleSession {
  id             String       @id @default(cuid())
  coupleAccessId String
  coupleAccess   CoupleAccess @relation(fields: [coupleAccessId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  @@index([expiresAt])
}

// =============================================================================
// Гости свадьбы + статус RSVP (проставляется вручную). Каждый человек — строка.
// =============================================================================

enum GuestStatus {
  COMING
  NOT_COMING
  MAYBE
  NO_ANSWER
}

enum GuestSide {
  BRIDE
  GROOM
  COMMON
}

model Guest {
  id         String        @id @default(cuid())
  weddingId  String
  wedding    Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name       String
  status     GuestStatus   @default(NO_ANSWER)
  side       GuestSide?
  groupLabel String?
  tableId    String?
  table      SeatingTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  sortOrder  Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([weddingId])
  @@index([tableId])
}

// =============================================================================
// Рассадка — столы (привязка гостя к столу через Guest.tableId)
// =============================================================================

model SeatingTable {
  id        String   @id @default(cuid())
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name      String
  capacity  Int      @default(0)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  guests    Guest[]

  @@index([weddingId])
}

// =============================================================================
// Couple-activity — лог правок пары для бейджа «пара внесла изменения»
// =============================================================================

enum CoupleArea {
  GUESTS
  SEATING
}

model CoupleActivity {
  id        String     @id @default(cuid())
  weddingId String
  wedding   Wedding    @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  area      CoupleArea
  summary   String
  createdAt DateTime   @default(now())

  @@index([weddingId, area, createdAt])
}

// =============================================================================
// База подрядчиков агентства (справочник, скоуп по agencyId, не per-wedding)
// =============================================================================

model AgencyVendor {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name      String
  service   String
  contact   String?
  link      String?
  priceNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
}

// =============================================================================
// События свадьбы — вехи с датами (роспись, банкет…), опционально видны паре
// =============================================================================

model WeddingEvent {
  id              String   @id @default(cuid())
  weddingId       String
  wedding         Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  title           String
  date            DateTime
  startMinutes    Int?
  description     String?
  visibleToCouple Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([weddingId, date])
}

// =============================================================================
// Удобство агентства (agency-only): контакты пары, заметки, оплаты от пары
// =============================================================================

model WeddingContact {
  id        String   @id @default(cuid())
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  label     String // пометка: «Мария», «WhatsApp жениха»
  value     String // номер / ник / email
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weddingId])
}

model WeddingNote {
  id         String   @id @default(cuid())
  weddingId  String
  wedding    Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  body       String
  authorName String? // имя участника агентства на момент записи
  createdAt  DateTime @default(now())

  @@index([weddingId, createdAt])
}

model AgencyPayment {
  id        String   @id @default(cuid())
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  amount    Int      @default(0) // рубли
  paidOn    DateTime
  note      String?
  createdAt DateTime @default(now())

  @@index([weddingId, paidOn])
}

// =============================================================================
// Шаблоны агентства (анкеты/чек-листы/тайминги/бюджеты) — content в JSON
// =============================================================================

enum TemplateType {
  QUESTIONNAIRE
  CHECKLIST
  TIMELINE
  BUDGET
}

model Template {
  id        String       @id @default(cuid())
  agencyId  String
  agency    Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  type      TemplateType
  name      String
  content   Json // QUESTIONNAIRE: {questions:string[]}; CHECKLIST/TIMELINE/BUDGET: {items:[...]}
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([agencyId, type])
}

// =============================================================================
// Запросы паре (канал агентство→пара): анкета или задача, инбокс + вложения
// =============================================================================

enum RequestKind {
  QUESTIONNAIRE
  TASK
}

enum RequestStatus {
  OPEN
  DONE
}

model CoupleRequest {
  id          String        @id @default(cuid())
  weddingId   String
  wedding     Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  kind        RequestKind
  title       String
  message     String? // текст просьбы (для TASK) или вступление к анкете
  linkTo      String? // slug раздела для TASK: guests/seating/… (плашка)
  status      RequestStatus @default(OPEN)
  coupleReply String? // короткий ответ пары на задачу (для TASK)
  createdAt   DateTime      @default(now())
  respondedAt DateTime?

  questions   RequestQuestion[]
  attachments RequestAttachment[]

  @@index([weddingId, status])
}

model RequestQuestion {
  id         String        @id @default(cuid())
  requestId  String
  request    CoupleRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  prompt     String
  answerText String? // свободный текст-ответ пары
  sortOrder  Int           @default(0)

  @@index([requestId])
}

model RequestAttachment {
  id         String        @id @default(cuid())
  requestId  String
  request    CoupleRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  storageKey String
  name       String
  mime       String
  size       Int
  createdAt  DateTime      @default(now())

  @@index([requestId])
}
